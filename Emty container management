<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Empty Container — Inspection & Barging</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0a0e1a;--bg2:#0f1629;--bg3:#141d35;--bg4:#1a2440;
  --cyan:#00d4ff;--cyan2:#00a8cc;--green:#00ff9d;--green2:#00cc7a;
  --red:#ff4757;--yellow:#ffd32a;--orange:#ff6b35;--purple:#a855f7;
  --text:#e2e8f0;--text2:#94a3b8;--text3:#64748b;
  --border:#1e2d4a;--border2:#253558;
  --card:#0f1629;
}
body{font-family:'Segoe UI',Tahoma,sans-serif;background:var(--bg);color:var(--text);font-size:13px;overflow:hidden;height:100vh}

/* LOGIN */
#login-screen{position:fixed;inset:0;background:var(--bg);display:flex;align-items:center;justify-content:center;z-index:200}
.login-wrap{width:380px}
.login-badge{display:inline-block;background:rgba(0,212,255,.1);border:1px solid rgba(0,212,255,.3);color:var(--cyan);font-size:10px;font-weight:700;letter-spacing:.12em;padding:4px 12px;border-radius:20px;margin-bottom:20px;text-transform:uppercase}
.login-title{font-size:26px;font-weight:700;color:#fff;margin-bottom:4px}
.login-title em{color:var(--cyan);font-style:normal}
.login-sub{color:var(--text2);font-size:12px;margin-bottom:28px}
.login-lbl{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);margin-bottom:5px;display:block}
.login-inp{width:100%;background:var(--bg3);border:1px solid var(--border2);color:var(--text);padding:10px 14px;font-size:13px;border-radius:8px;font-family:inherit;margin-bottom:12px;transition:border .2s}
.login-inp:focus{outline:none;border-color:var(--cyan);box-shadow:0 0 0 2px rgba(0,212,255,.1)}
.login-btn{width:100%;padding:11px;background:var(--cyan);color:#0a0e1a;font-size:13px;font-weight:700;border:none;border-radius:8px;cursor:pointer;font-family:inherit;transition:all .2s;margin-top:4px}
.login-btn:hover{background:var(--cyan2)}
.login-err{background:rgba(255,71,87,.1);border:1px solid rgba(255,71,87,.3);color:var(--red);padding:8px 12px;border-radius:6px;font-size:12px;margin-top:8px;display:none}

/* APP */
#app{display:none;flex-direction:column;height:100vh}
#app.visible{display:flex}

/* TOPBAR */
#topbar{background:var(--bg2);border-bottom:1px solid var(--border);padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:54px;flex-shrink:0}
.tb-brand{display:flex;align-items:center;gap:10px}
.tb-logo{width:30px;height:30px;background:linear-gradient(135deg,var(--cyan),var(--purple));border-radius:7px;display:flex;align-items:center;justify-content:center}
.tb-sub{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.06em}
.tb-title{font-size:15px;font-weight:700;color:#fff}
.tb-title em{color:var(--cyan);font-style:normal}
.tb-right{display:flex;align-items:center;gap:12px}
.tb-user{font-size:11px;color:var(--text3)}
.tb-user strong{color:var(--text)}
.btn-logout{padding:5px 12px;background:rgba(255,71,87,.1);border:1px solid rgba(255,71,87,.25);color:var(--red);font-size:11px;border-radius:6px;cursor:pointer;font-family:inherit}
.btn-logout:hover{background:rgba(255,71,87,.2)}

/* TABS */
#tabs{background:var(--bg2);border-bottom:1px solid var(--border);padding:0 24px;display:flex;gap:2px;flex-shrink:0}
.tab{padding:10px 16px;font-size:12px;font-weight:500;color:var(--text3);cursor:pointer;border-bottom:2px solid transparent;display:flex;align-items:center;gap:6px;margin-bottom:-1px;transition:color .15s}
.tab:hover{color:var(--text2)}
.tab.active{color:var(--cyan);border-bottom-color:var(--cyan);font-weight:600}

/* CONTENT */
#content{flex:1;overflow-y:auto;padding:18px 24px;scrollbar-width:thin;scrollbar-color:var(--border2) transparent}
.screen{display:none}.screen.active{display:block}

/* STATS */
.stats-row{display:flex;gap:10px;margin-bottom:16px}
.stat-card{flex:1;background:var(--card);border:1px solid var(--border);border-radius:10px;padding:14px 16px;position:relative;overflow:hidden}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px}
.stat-card.cyan::before{background:var(--cyan)}.stat-card.green::before{background:var(--green)}
.stat-card.red::before{background:var(--red)}.stat-card.yellow::before{background:var(--yellow)}
.stat-card.orange::before{background:var(--orange)}.stat-card.purple::before{background:var(--purple)}
.stat-lbl{font-size:9px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text3);margin-bottom:7px}
.stat-val{font-size:26px;font-weight:700;line-height:1}
.stat-val.cyan{color:var(--cyan)}.stat-val.green{color:var(--green)}.stat-val.red{color:var(--red)}
.stat-val.yellow{color:var(--yellow)}.stat-val.orange{color:var(--orange)}.stat-val.purple{color:var(--purple)}
.stat-sub2{font-size:10px;color:var(--text3);margin-top:4px}

/* TOOLBAR */
.toolbar{display:flex;align-items:center;gap:8px;margin-bottom:12px;flex-wrap:wrap}
.srch{display:flex;align-items:center;gap:7px;background:var(--bg3);border:1px solid var(--border);border-radius:7px;padding:6px 11px;flex:0 0 260px}
.srch input{background:none;border:none;color:var(--text);font-size:12px;outline:none;font-family:inherit;width:100%}
.srch input::placeholder{color:var(--text3)}
.ml{margin-left:auto}
.btn{padding:6px 13px;font-size:12px;font-weight:500;border-radius:7px;cursor:pointer;font-family:inherit;transition:all .15s;display:inline-flex;align-items:center;gap:5px;border:1px solid}
.btn-p{background:rgba(0,212,255,.1);border-color:rgba(0,212,255,.3);color:var(--cyan)}
.btn-p:hover{background:rgba(0,212,255,.18)}
.btn-g{background:rgba(0,255,157,.08);border-color:rgba(0,255,157,.25);color:var(--green)}
.btn-g:hover{background:rgba(0,255,157,.15)}
.btn-d{background:rgba(255,71,87,.08);border-color:rgba(255,71,87,.25);color:var(--red)}
.btn-d:hover{background:rgba(255,71,87,.15)}

/* FILTER TABS */
.ftabs{display:flex;gap:5px;margin-bottom:12px}
.ftab{padding:4px 13px;font-size:11px;border-radius:20px;cursor:pointer;background:var(--bg3);border:1px solid var(--border);color:var(--text2);transition:all .15s}
.ftab.active{background:rgba(0,212,255,.1);border-color:rgba(0,212,255,.35);color:var(--cyan)}

/* TABLE */
.tbl{overflow-x:auto;border-radius:9px;border:1px solid var(--border)}
table{width:100%;border-collapse:collapse;font-size:12px}
th{background:var(--bg3);padding:8px 10px;text-align:left;font-weight:600;color:var(--text3);font-size:10px;letter-spacing:.04em;text-transform:uppercase;border-bottom:1px solid var(--border);white-space:nowrap}
td{padding:9px 10px;border-bottom:1px solid rgba(30,45,74,.6);color:var(--text);white-space:nowrap;vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:rgba(255,255,255,.015)}
.td-n{color:var(--cyan);font-weight:600}
.acts{display:flex;gap:4px}
.ibtn{width:26px;height:26px;border-radius:5px;display:flex;align-items:center;justify-content:center;cursor:pointer;border:1px solid;font-size:12px;transition:all .15s}
.ibtn.e{border-color:rgba(0,212,255,.25);color:var(--cyan)}.ibtn.e:hover{background:rgba(0,212,255,.1)}
.ibtn.d{border-color:rgba(255,71,87,.25);color:var(--red)}.ibtn.d:hover{background:rgba(255,71,87,.1)}
.ibtn.s{border-color:rgba(0,255,157,.25);color:var(--green)}.ibtn.s:hover{background:rgba(0,255,157,.08)}

/* BADGES */
.badge{display:inline-flex;align-items:center;padding:2px 9px;border-radius:4px;font-size:10px;font-weight:700}
.b-on{background:rgba(0,255,157,.1);border:1px solid rgba(0,255,157,.3);color:var(--green)}
.b-off{background:rgba(100,116,139,.1);border:1px solid rgba(100,116,139,.3);color:var(--text3)}
.b-yt{background:rgba(255,211,42,.08);border:1px solid rgba(255,211,42,.3);color:var(--yellow)}
.b-sv{background:rgba(0,255,157,.1);border:1px solid rgba(0,255,157,.3);color:var(--green)}
.b-ns{background:rgba(255,211,42,.08);border:1px solid rgba(255,211,42,.3);color:var(--yellow)}
.cbdg{display:inline-flex;align-items:center;justify-content:center;width:28px;height:28px;border-radius:50%;font-size:11px;font-weight:700}
.cbdg.dm{background:rgba(255,71,87,.15);color:var(--red)}
.cbdg.cl{background:rgba(0,255,157,.1);color:var(--green)}
.cbdg.rp{background:rgba(0,212,255,.1);color:var(--cyan)}
.cbdg.tm{background:rgba(255,211,42,.08);color:var(--yellow)}

/* MODAL */
.ov{position:fixed;inset:0;background:rgba(0,0,0,.65);z-index:100;display:none;align-items:center;justify-content:center;backdrop-filter:blur(2px)}
.ov.open{display:flex}
.modal{background:var(--bg2);border:1px solid var(--border2);border-radius:11px;padding:22px;width:490px;max-width:95vw;max-height:90vh;overflow-y:auto;box-shadow:0 16px 50px rgba(0,0,0,.5)}
.modal-lg{width:620px}
.modal-sm{width:360px}
.m-title{font-size:15px;font-weight:700;color:#fff;margin-bottom:3px}
.m-sub{font-size:11px;color:var(--text3);margin-bottom:18px}
.fg{display:flex;flex-direction:column;gap:4px}
.fl{font-size:10px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--text3)}
.fi{padding:7px 10px;font-size:12px;background:var(--bg3);border:1px solid var(--border2);border-radius:6px;color:var(--text);font-family:inherit;transition:border .15s}
.fi:focus{outline:none;border-color:var(--cyan)}
select.fi option{background:var(--bg2)}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:11px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:11px}
.mf{display:flex;gap:8px;margin-top:18px;justify-content:flex-end}
.mt{margin-top:11px}

/* TOAST */
#toast{position:fixed;bottom:22px;right:22px;background:var(--bg3);border:1px solid var(--border2);color:var(--text);padding:9px 15px;border-radius:7px;font-size:12px;z-index:999;opacity:0;transition:opacity .25s;pointer-events:none}
#toast.show{opacity:1}
#toast.ok{border-color:rgba(0,255,157,.4);color:var(--green)}
#toast.err{border-color:rgba(255,71,87,.4);color:var(--red)}

/* UPLOAD */
.upl{border:2px dashed var(--border2);border-radius:9px;padding:28px;text-align:center;cursor:pointer;transition:all .2s}
.upl:hover{border-color:var(--cyan);background:rgba(0,212,255,.03)}

/* GANTT */
.gantt-no{padding:40px;text-align:center;color:var(--text3)}
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-wrap">
    <div class="login-badge">🚢 Empty Container Management Department</div>
    <div class="login-title">EMTY CONTAINER<br><em>INSPECTION</em> — BARGING</div>
    <div class="login-sub">Cảng Thạnh Phước — Hệ thống quản lý sà lan</div>
    <label class="login-lbl">Username</label>
    <input class="login-inp" id="lu" placeholder="Nhập username" autocomplete="off">
    <label class="login-lbl">Key</label>
    <input class="login-inp" id="lk" type="password" placeholder="Nhập key" onkeydown="if(event.key==='Enter')doLogin()">
    <div class="login-err" id="lerr"></div>
    <button class="login-btn" onclick="doLogin()" id="lbtn">Đăng nhập</button>
  </div>
</div>

<!-- APP -->
<div id="app">
  <div id="topbar">
    <div class="tb-brand">
      <div class="tb-logo">🚢</div>
      <div>
        <div class="tb-sub">Empty Container Dept.</div>
        <div class="tb-title">INSPECTION — <em>BARGING</em></div>
      </div>
    </div>
    <div class="tb-right">
      <div class="tb-user">Xin chào, <strong id="tbname">—</strong></div>
      <button class="btn-logout" onclick="doLogout()">Đăng xuất</button>
    </div>
  </div>
  <div id="tabs">
    <div class="tab active" onclick="switchTab('barges',this)">🚢 Quản lý sà lan</div>
    <div class="tab" onclick="switchTab('voyages',this)">📋 Kế hoạch sà lan</div>
    <div class="tab" onclick="switchTab('gantt',this)">📊 Sơ đồ Gantt</div>
    <div class="tab" onclick="switchTab('survey',this)">📄 Báo cáo Survey</div>
  </div>
  <div id="content">

    <!-- BARGES -->
    <div class="screen active" id="screen-barges">
      <div class="stats-row" id="bstats"></div>
      <div class="toolbar">
        <div class="srch"><span style="color:var(--text3)">🔍</span><input placeholder="Tìm kiếm sà lan..." id="bsrch" oninput="renderBarges()"></div>
        <div class="ml" style="display:flex;gap:7px">
          <button class="btn btn-g" onclick="exportBargesExcel()">⬆ Export Excel</button>
          <button class="btn btn-p" onclick="openBargeModal()">⊕ Thêm sà lan mới</button>
        </div>
      </div>
      <div class="tbl">
        <table><thead><tr>
          <th style="width:44px">STT</th><th>TÊN SÀ LAN</th><th>SỐ ĐĂNG KÝ</th>
          <th>TRỌNG TẢI (TẤN)</th><th>SỐ LƯỢNG TEUS</th><th>NĂM ĐÓNG</th>
          <th>TÌNH TRẠNG</th><th style="width:80px">THAO TÁC</th>
        </tr></thead><tbody id="btbody"></tbody></table>
      </div>
    </div>

    <!-- VOYAGES -->
    <div class="screen" id="screen-voyages">
      <div class="stats-row" id="vstats"></div>
      <div class="toolbar">
        <div class="srch"><span style="color:var(--text3)">🔍</span><input placeholder="Tìm theo sà lan, voyage, cảng..." id="vsrch" oninput="renderVoyages()"></div>
        <div class="ml" style="display:flex;gap:7px">
          <button class="btn btn-g" onclick="exportVoyagesExcel()">⬆ Export Excel</button>
          <button class="btn btn-p" onclick="openVoyageModal()">⊕ Thêm kế hoạch sà lan</button>
        </div>
      </div>
      <div class="ftabs">
        <div class="ftab active" onclick="setVF('all',this)">⊕ Tất cả</div>
        <div class="ftab" onclick="setVF('kehoach',this)">📋 Kế hoạch</div>
        <div class="ftab" onclick="setVF('hoanthanh',this)">✔ Hoàn thành</div>
        <div class="ftab" onclick="setVF('chuasurvey',this)">⚠ Chưa survey</div>
      </div>
      <div class="tbl">
        <table><thead><tr>
          <th style="width:44px">STT</th><th>SÀ LAN</th><th>VOYAGE</th><th>LOẠI HÀNG</th>
          <th>SỐ LƯỢNG</th><th>POL</th><th>POD</th><th>ETA</th><th>ETD</th>
          <th>BẮT ĐẦU LÀM HÀNG</th><th>KẾT THÚC LÀM HÀNG</th><th>SURVEY</th>
          <th style="width:100px">THAO TÁC</th>
        </tr></thead><tbody id="vtbody"></tbody></table>
      </div>
    </div>

    <!-- GANTT -->
    <div class="screen" id="screen-gantt">
      <div class="stats-row" id="gstats"></div>
      <div class="toolbar" style="margin-bottom:12px">
        <select class="fi" id="gfbarge" onchange="renderGantt()" style="width:200px">
          <option value="">-- Tất cả sà lan --</option>
        </select>
        <select class="fi" id="gfrange" onchange="renderGantt()" style="width:140px">
          <option value="week">Tuần này</option>
          <option value="month" selected>Tháng này</option>
          <option value="3month">3 tháng</option>
        </select>
      </div>
      <div id="gantt-wrap" style="border:1px solid var(--border);border-radius:9px;overflow:auto;max-height:calc(100vh - 320px)"></div>
      <div style="display:flex;gap:16px;margin-top:10px;flex-wrap:wrap">
        <div style="display:flex;align-items:center;gap:6px;font-size:11px;color:var(--text2)"><div style="width:14px;height:14px;border-radius:3px;background:rgba(0,212,255,.35)"></div>ETA → ETD (Tại cảng)</div>
        <div style="display:flex;align-items:center;gap:6px;font-size:11px;color:var(--text2)"><div style="width:14px;height:14px;border-radius:3px;background:rgba(0,255,157,.35)"></div>Bắt đầu → Kết thúc (Làm hàng)</div>
        <div style="display:flex;align-items:center;gap:6px;font-size:11px;color:var(--text2)"><div style="width:14px;height:14px;border-radius:3px;background:rgba(255,211,42,.25)"></div>Thời gian chờ</div>
      </div>
    </div>

    <!-- SURVEY -->
    <div class="screen" id="screen-survey">
      <div class="stats-row" id="sstats-top"></div>
      <div class="toolbar">
        <div class="srch"><span style="color:var(--text3)">🔍</span><input placeholder="Tìm sà lan..." id="ssrch" oninput="renderSurveys()"></div>
        <input type="date" class="fi" id="sfrom" onchange="renderSurveys()" style="width:135px">
        <input type="date" class="fi" id="sto" onchange="renderSurveys()" style="width:135px">
        <select class="fi" id="sfbarge" onchange="renderSurveys()" style="width:170px">
          <option value="">Tất cả sà lan</option>
        </select>
        <div class="ml" style="display:flex;gap:7px">
          <button class="btn btn-g" onclick="exportSurveyExcel()">⬆ Export Excel</button>
          <button class="btn btn-p" onclick="openImportSurvey()">⬆ Import</button>
          <button class="btn btn-p" onclick="openSurveyModal()">⊕ Thêm survey</button>
        </div>
      </div>
      <div class="stats-row" id="sstats-f" style="margin-bottom:12px"></div>
      <div class="tbl">
        <table><thead><tr>
          <th style="width:44px">STT</th><th>SÀ LAN</th><th>VOYAGE</th><th>LOẠI</th>
          <th>SỐ LƯỢNG</th><th>DAMAGED</th><th>CLEAN</th><th>REPO</th><th>TERMITES</th>
          <th>TỔNG</th><th>NGÀY SURVEY</th><th style="width:80px">THAO TÁC</th>
        </tr></thead><tbody id="stbody"></tbody></table>
      </div>
    </div>

  </div>
</div>

<div id="toast"></div>

<!-- MODAL BARGE -->
<div class="ov" id="mb">
  <div class="modal">
    <div class="m-title" id="mb-title">Thêm sà lan mới</div>
    <div class="m-sub">Nhập thông tin sà lan</div>
    <input type="hidden" id="mb-seq">
    <div class="g2">
      <div class="fg"><label class="fl">Mã sà lan *</label><input class="fi" id="mb-code" placeholder="VD: DL02"></div>
      <div class="fg"><label class="fl">Tên sà lan *</label><input class="fi" id="mb-ten" placeholder="VD: Đạt Long 02"></div>
    </div>
    <div class="fg mt"><label class="fl">Số đăng ký / SĐT liên hệ</label><input class="fi" id="mb-sdk" placeholder="VD: SG-9379 / 0363622075"></div>
    <div class="g3 mt">
      <div class="fg"><label class="fl">Trọng tải (tấn)</label><input class="fi" id="mb-tt" type="number" placeholder="0"></div>
      <div class="fg"><label class="fl">Số lượng TEUs</label><input class="fi" id="mb-teus" type="number" placeholder="0"></div>
      <div class="fg"><label class="fl">Năm đóng</label><input class="fi" id="mb-nd" placeholder="2025"></div>
    </div>
    <div class="g2 mt">
      <div class="fg"><label class="fl">Tình trạng</label>
        <select class="fi" id="mb-tt2">
          <option value="HOAT_DONG">Hoạt động</option>
          <option value="NGUNG">Ngưng hoạt động</option>
          <option value="BAO_TRI">Bảo trì</option>
        </select>
      </div>
      <div class="fg"><label class="fl">Ghi chú</label><input class="fi" id="mb-gc"></div>
    </div>
    <div class="mf">
      <button class="btn" onclick="closeOv('mb')" style="border-color:var(--border2);color:var(--text2)">Huỷ</button>
      <button class="btn btn-p" onclick="saveBarge()">Lưu</button>
    </div>
  </div>
</div>

<!-- MODAL VOYAGE -->
<div class="ov" id="mv">
  <div class="modal modal-lg">
    <div class="m-title" id="mv-title">Thêm kế hoạch sà lan</div>
    <div class="m-sub">Nhập thông tin chuyến tàu</div>
    <input type="hidden" id="mv-seq">
    <div class="g2">
      <div class="fg"><label class="fl">Sà lan *</label>
        <select class="fi" id="mv-sl"><option value="">-- Chọn sà lan --</option></select>
      </div>
      <div class="fg"><label class="fl">Voyage No</label><input class="fi" id="mv-vno" placeholder="VD: 0013"></div>
    </div>
    <div class="g3 mt">
      <div class="fg"><label class="fl">Loại hàng</label>
        <select class="fi" id="mv-lh"><option>Container</option><option>Bulk</option><option>Khác</option></select>
      </div>
      <div class="fg"><label class="fl">Số lượng</label><input class="fi" id="mv-sl2" placeholder="VD: 96 TEUs"></div>
      <div class="fg"><label class="fl">POL</label><input class="fi" id="mv-pol" placeholder="SSIT"></div>
    </div>
    <div class="g2 mt">
      <div class="fg"><label class="fl">POD</label><input class="fi" id="mv-pod" placeholder="TPP"></div>
      <div class="fg"></div>
    </div>
    <div class="g2 mt">
