<script>
const GAS_URL = 'YOUR_GAS_DEPLOY_URL_HERE'; // ← Thay URL deploy GAS của bạn

let S = { user:null, barges:[], voyages:[], surveys:[], vf:'all', importRows:[] };

// ===== API =====
async function api(action, params={}) {
  const r = await fetch(GAS_URL+'?action='+action+'&'+new URLSearchParams(params));
  return r.json();
}
async function post(body) {
  const r = await fetch(GAS_URL,{method:'POST',body:JSON.stringify(body),headers:{'Content-Type':'application/json'}});
  return r.json();
}

// ===== LOGIN =====
async function doLogin() {
  const u=document.getElementById('lu').value.trim(), k=document.getElementById('lk').value.trim();
  if(!u||!k){showErr('Vui lòng nhập đầy đủ');return;}
  const btn=document.getElementById('lbtn'); btn.textContent='Đang đăng nhập...'; btn.disabled=true;
  try {
    const res=await api('login',{username:u,key:k});
    if(res.success){
      S.user=res;
      document.getElementById('tbname').textContent=res.fullname;
      document.getElementById('login-screen').style.display='none';
      document.getElementById('app').classList.add('visible');
      await loadAll();
    } else showErr(res.error||'Đăng nhập thất bại');
  } catch(e){showErr('Lỗi: '+e.message);}
  finally{btn.textContent='Đăng nhập';btn.disabled=false;}
}
function showErr(m){const e=document.getElementById('lerr');e.textContent=m;e.style.display='block';}
function doLogout(){S.user=null;document.getElementById('app').classList.remove('visible');document.getElementById('login-screen').style.display='flex';document.getElementById('lk').value='';}

// ===== LOAD =====
async function loadAll(){
  try{
    const[b,v,s]=await Promise.all([api('getBarges'),api('getVoyages'),api('getSurveys')]);
    S.barges=b.data||[]; S.voyages=v.data||[]; S.surveys=s.data||[];
    renderBarges(); renderVoyages(); renderGantt(); renderSurveys(); fillDropdowns();
  }catch(e){toast('Lỗi load: '+e.message,'err');}
}

// ===== TABS =====
function switchTab(n,el){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('screen-'+n).classList.add('active');
  if(n==='gantt') renderGantt();
}

// ===== BARGES =====
function renderBarges(){
  const q=(document.getElementById('bsrch').value||'').toLowerCase();
  const rows=S.barges.filter(b=>!q||b.ten.toLowerCase().includes(q)||b.code.toLowerCase().includes(q)||(b.so_dang_ky||'').toLowerCase().includes(q));
  const tot=S.barges.length, on=S.barges.filter(b=>b.tinh_trang==='HOAT_DONG').length,
        off=S.barges.filter(b=>b.tinh_trang==='NGUNG').length, bt=S.barges.filter(b=>b.tinh_trang==='BAO_TRI').length,
        teus=S.barges.filter(b=>b.tinh_trang==='HOAT_DONG').reduce((s,b)=>s+b.so_teus,0);
  document.getElementById('bstats').innerHTML=
    sc('TỔNG SÀ LAN',fmt(tot),'cyan')+sc('ĐANG HOẠT ĐỘNG',fmt(on),'green')+
    sc('NGỪNG HOẠT ĐỘNG',fmt(off),'red')+sc('BẢO TRÌ',fmt(bt),'yellow')+
    sc('TEUS ĐANG HOẠT ĐỘNG',fmt(teus),'orange');
  const tb=document.getElementById('btbody');
  if(!rows.length){tb.innerHTML=`<tr><td colspan="8" style="text-align:center;padding:32px;color:var(--text3)">Không có dữ liệu</td></tr>`;return;}
  tb.innerHTML=rows.map((b,i)=>`<tr>
    <td style="color:var(--text3)">${i+1}</td>
    <td class="td-n">${b.code} — ${b.ten}</td>
    <td>${b.so_dang_ky||'—'}</td>
    <td style="text-align:right">${fmt(b.trong_tai)}</td>
    <td style="text-align:right">${fmt(b.so_teus)}</td>
    <td>${b.nam_dong||'—'}</td>
    <td>${ttBadge(b.tinh_trang)}</td>
    <td><div class="acts">
      <div class="ibtn e" onclick='openBargeModal(${jstr(b)})' title="Sửa">✎</div>
      <div class="ibtn d" onclick="confDel('barge',${b.seq},'Xoá sà lan ${b.ten}?')" title="Xoá">🗑</div>
    </div></td>
  </tr>`).join('');
}
function ttBadge(t){
  if(t==='HOAT_DONG') return '<span class="badge b-on">HOẠT ĐỘNG</span>';
  if(t==='NGUNG') return '<span class="badge b-off">NGỪNG</span>';
  return '<span class="badge b-yt">BẢO TRÌ</span>';
}
function openBargeModal(b=null){
  document.getElementById('mb-title').textContent=b?'Chỉnh sửa sà lan':'Thêm sà lan mới';
  _v('mb-seq',b?b.seq:''); _v('mb-code',b?b.code:''); _v('mb-ten',b?b.ten:'');
  _v('mb-sdk',b?b.so_dang_ky:''); _v('mb-tt',b?b.trong_tai:''); _v('mb-teus',b?b.so_teus:'');
  _v('mb-nd',b?b.nam_dong:''); _v('mb-tt2',b?b.tinh_trang:'HOAT_DONG'); _v('mb-gc',b?b.ghi_chu:'');
  openOv('mb');
}
async function saveBarge(){
  const seq=_g('mb-seq'), code=_g('mb-code').trim(), ten=_g('mb-ten').trim();
  if(!code||!ten){toast('Vui lòng nhập Mã và Tên','err');return;}
  const res=await post({action:seq?'updateBarge':'saveBarge',seq,code,ten,
    so_dang_ky:_g('mb-sdk'),trong_tai:_g('mb-tt'),so_teus:_g('mb-teus'),
    nam_dong:_g('mb-nd'),tinh_trang:_g('mb-tt2'),ghi_chu:_g('mb-gc')});
  if(res.success){toast(seq?'Đã cập nhật':'Đã thêm sà lan','ok');closeOv('mb');await loadAll();}
  else toast(res.error||'Lỗi','err');
}

// ===== VOYAGES =====
function setVF(f,el){
  S.vf=f;
  document.querySelectorAll('.ftab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active'); renderVoyages();
}
function renderVoyages(){
  const q=(document.getElementById('vsrch').value||'').toLowerCase();
  let rows=S.voyages.filter(v=>{
    if(q&&!v.ten_salan.toLowerCase().includes(q)&&!(v.voyage_no||'').includes(q)&&!v.pol.toLowerCase().includes(q)&&!v.pod.toLowerCase().includes(q)) return false;
    if(S.vf==='kehoach') return v.trang_thai_survey!=='Đã survey';
    if(S.vf==='hoanthanh') return v.trang_thai_survey==='Đã survey';
    if(S.vf==='chuasurvey') return v.trang_thai_survey!=='Đã survey';
    return true;
  });
  const tot=S.voyages.length, teus=S.voyages.reduce((s,v)=>s+(parseInt(v.so_luong)||0),0),
        cs=S.voyages.filter(v=>v.trang_thai_survey!=='Đã survey').length,
        ht=S.voyages.filter(v=>v.trang_thai_survey==='Đã survey').length,
        tc=S.voyages.filter(v=>v.trang_thai_survey!=='Đã survey').reduce((s,v)=>s+(parseInt(v.so_luong)||0),0);
  document.getElementById('vstats').innerHTML=
    sc('TỔNG SÀ LAN',fmt(tot),'cyan')+sc('TỔNG TEUS',fmt(teus),'cyan')+
    sc('CHƯA SURVEY',fmt(cs),'yellow')+sc('HOÀN THÀNH',fmt(ht),'green')+sc('TEUS CHỜ DỠ',fmt(tc),'red');
  const tb=document.getElementById('vtbody');
  if(!rows.length){tb.innerHTML=`<tr><td colspan="13" style="text-align:center;padding:32px;color:var(--text3)">Không có dữ liệu</td></tr>`;return;}
  tb.innerHTML=rows.map((v,i)=>`<tr>
    <td style="color:var(--text3)">${i+1}</td>
    <td class="td-n">${v.ten_salan}</td>
    <td style="color:var(--text2)">${v.voyage_no||'—'}</td>
    <td>${v.loai_hang}</td><td>${v.so_luong||'—'}</td>
    <td>${v.pol||'—'}</td><td>${v.pod||'—'}</td>
    <td style="font-size:11px">${v.eta||'—'}</td>
    <td style="font-size:11px">${v.etd||'—'}</td>
    <td style="font-size:11px">${v.bat_dau||'—'}</td>
    <td style="font-size:11px">${v.ket_thuc||'—'}</td>
    <td>${v.trang_thai_survey==='Đã survey'?'<span class="badge b-sv">✔ Đã survey</span>':'<span class="badge b-ns">Chưa survey</span>'}</td>
    <td><div class="acts">
      <div class="ibtn s" onclick='quickSurvey(${jstr(v)})' title="Thêm survey">📋</div>
      <div class="ibtn e" onclick='openVoyageModal(${jstr(v)})' title="Sửa">✎</div>
      <div class="ibtn d" onclick="confDel('voyage',${v.seq},'Xoá voyage ${v.voyage_no||''} — ${v.ten_salan}?')" title="Xoá">🗑</div>
    </div></td>
  </tr>`).join('');
}
function openVoyageModal(v=null){
  document.getElementById('mv-title').textContent=v?'Chỉnh sửa kế hoạch':'Thêm kế hoạch sà lan';
  _v('mv-seq',v?v.seq:''); _v('mv-vno',v?v.voyage_no:''); _v('mv-lh',v?v.loai_hang:'Container');
  _v('mv-sl2',v?v.so_luong:''); _v('mv-pol',v?v.pol:'SSIT'); _v('mv-pod',v?v.pod:'TPP');
  _v('mv-eta',v?toLocal(v.eta):''); _v('mv-etd',v?toLocal(v.etd):'');
  _v('mv-bd',v?toLocal(v.bat_dau):''); _v('mv-kt',v?toLocal(v.ket_thuc):'');
  _v('mv-gc',v?v.ghi_chu:'');
  const sel=document.getElementById('mv-sl');
  sel.innerHTML='<option value="">-- Chọn sà lan --</option>'+
    S.barges.map(b=>`<option value="${b.code}" data-ten="${b.ten}" ${v&&v.ma_salan===b.code?'selected':''}>${b.code} — ${b.ten}</option>`).join('');
  openOv('mv');
}
async function saveVoyage(){
  const seq=_g('mv-seq'), sel=document.getElementById('mv-sl'), maSalan=sel.value;
  const opt=sel.options[sel.selectedIndex], tenSalan=opt?opt.dataset.ten||'':'';
  if(!maSalan){toast('Vui lòng chọn sà lan','err');return;}
  const res=await post({action:seq?'updateVoyage':'saveVoyage',seq,
    ma_salan:maSalan,ten_salan:tenSalan,voyage_no:_g('mv-vno'),loai_hang:_g('mv-lh'),
    so_luong:_g('mv-sl2'),pol:_g('mv-pol'),pod:_g('mv-pod'),
    eta:_g('mv-eta'),etd:_g('mv-etd'),bat_dau:_g('mv-bd'),ket_thuc:_g('mv-kt'),
    trang_thai_survey:seq?undefined:'Chưa survey',ghi_chu:_g('mv-gc')});
  if(res.success){toast(seq?'Đã cập nhật':'Đã thêm kế hoạch','ok');closeOv('mv');await loadAll();}
  else toast(res.error||'Lỗi','err');
}
function quickSurvey(v){
  switchTab('survey',document.querySelectorAll('.tab')[3]);
  setTimeout(()=>openSurveyModal(null,v),80);
}

// ===== GANTT =====
function renderGantt(){
  const bf=document.getElementById('gfbarge').value, range=document.getElementById('gfrange').value;
  const now=new Date();
  let start,end;
  if(range==='week'){start=new Date(now);start.setDate(now.getDate()-now.getDay()+1);start.setHours(0,0,0,0);end=new Date(start);end.setDate(start.getDate()+6);}
  else if(range==='month'){start=new Date(now.getFullYear(),now.getMonth(),1);end=new Date(now.getFullYear(),now.getMonth()+1,0);}
  else{start=new Date(now.getFullYear(),now.getMonth()-1,1);end=new Date(now.getFullYear(),now.getMonth()+2,0);}
  end.setHours(23,59,59,999);

  let rows=S.voyages.filter(v=>{
    if(bf&&v.ma_salan!==bf)return false;
    const eta=v.eta?parseDt(v.eta):null, etd=v.etd?parseDt(v.etd):null;
    if(!eta&&!etd)return false;
    if(eta&&etd) return eta<=end&&etd>=start;
    if(eta) return eta>=start&&eta<=end;
    return false;
  });

  // Stats
  let lhSum=0,lhCnt=0,cangSum=0,cangCnt=0;
  rows.forEach(v=>{
    if(v.bat_dau&&v.ket_thuc){const h=(parseDt(v.ket_thuc)-parseDt(v.bat_dau))/3600000;if(h>0){lhSum+=h;lhCnt++;}}
    if(v.eta&&v.etd){const h=(parseDt(v.etd)-parseDt(v.eta))/3600000;if(h>0){cangSum+=h;cangCnt++;}}
  });
  const avgLH=lhCnt?lhSum/lhCnt:0, avgCang=cangCnt?cangSum/cangCnt:0, avgCho=Math.max(0,avgCang-avgLH);
  document.getElementById('gstats').innerHTML=
    sc('TỔNG KẾ HOẠCH',fmt(rows.length),'cyan')+
    sc('THỜI GIAN LÀM HÀNG TB',avgLH.toFixed(1)+'h','green')+
    sc('THỜI GIAN Ở CẢNG TB',avgCang.toFixed(1)+'h','cyan')+
    sc('THỜI GIAN CHỜ TB',avgCho.toFixed(1)+'h','yellow');

  const wrap=document.getElementById('gantt-wrap');
  if(!rows.length){wrap.innerHTML='<div class="gantt-no">Không có kế hoạch trong khoảng thời gian này</div>';return;}

  const days=[];
  for(let d=new Date(start);d<=end;d.setDate(d.getDate()+1)) days.push(new Date(d));
  const DW=['CN','Th2','Th3','Th4','Th5','Th6','Th7'];
  const COL_W=80, LABEL_W=200, total_w=LABEL_W+days.length*COL_W;
  const dur_ms=end-start;

  let html=`<div style="min-width:${total_w}px;position:relative">`;
  // Header
  html+=`<div style="display:flex;background:var(--bg3);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:5">`;
  html+=`<div style="width:${LABEL_W}px;flex-shrink:0;padding:8px 12px;font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;border-right:1px solid var(--border);position:sticky;left:0;background:var(--bg3);z-index:6">SÀ LAN</div>`;
  days.forEach(d=>{
    const tod=d.toDateString()===now.toDateString();
    html+=`<div style="width:${COL_W}px;flex-shrink:0;border-right:1px solid var(--border);padding:6px 4px;text-align:center${tod?';background:rgba(0,212,255,.07)':''}">
      <div style="font-size:10px;font-weight:700;color:${tod?'var(--cyan)':'var(--text3)'}">${DW[d.getDay()]}</div>
      <div style="font-size:12px;color:${tod?'var(--cyan)':'var(--text)'};font-weight:${tod?700:400}">${d.getDate()}/${d.getMonth()+1}</div>
    </div>`;
  });
  html+=`</div>`;

  // Rows
  rows.forEach(v=>{
    const eta=v.eta?parseDt(v.eta):null, etd=v.etd?parseDt(v.etd):null;
    const bat=v.bat_dau?parseDt(v.bat_dau):null, ket=v.ket_thuc?parseDt(v.ket_thuc):null;
    const px=dt=>dt?Math.max(0,(dt-start)/dur_ms*days.length*COL_W):null;
    const etaX=px(eta), etdX=px(etd), batX=px(bat), ketX=px(ket);
    html+=`<div style="display:flex;border-bottom:1px solid rgba(30,45,74,.5);min-height:50px;position:relative">`;
    html+=`<div style="width:${LABEL_W}px;flex-shrink:0;background:var(--bg2);border-right:1px solid var(--border);padding:8px 12px;position:sticky;left:0;z-index:4">
      <div style="font-size:12px;color:var(--cyan);font-weight:600">${v.ten_salan}</div>
      <div style="font-size:10px;color:var(--text3);margin-top:2px">VOY: ${v.voyage_no||'—'}</div>
    </div>`;
    html+=`<div style="flex:1;position:relative;height:50px">`;
    // Grid lines
    days.forEach((_,i)=>html+=`<div style="position:absolute;top:0;bottom:0;left:${i*COL_W}px;width:1px;background:rgba(30,45,74,.4)"></div>`);
    // ETA→ETD
    if(etaX!==null&&etdX!==null&&etdX>etaX)
      html+=`<div style="position:absolute;top:7px;height:36px;left:${Math.max(0,etaX)}px;width:${Math.min(etdX,days.length*COL_W)-Math.max(0,etaX)}px;min-width:4px;background:rgba(0,212,255,.18);border:1px solid rgba(0,212,255,.4);border-radius:5px;display:flex;align-items:center;padding:0 6px;font-size:10px;color:var(--cyan);overflow:hidden;white-space:nowrap" title="ETA→ETD">${v.ten_salan}</div>`;
    // Làm hàng
    if(batX!==null&&ketX!==null&&ketX>batX)
      html+=`<div style="position:absolute;top:13px;height:24px;left:${Math.max(0,batX)}px;width:${Math.min(ketX,days.length*COL_W)-Math.max(0,batX)}px;min-width:4px;background:rgba(0,255,157,.2);border:1px solid rgba(0,255,157,.4);border-radius:4px;display:flex;align-items:center;padding:0 6px;font-size:10px;color:var(--green);overflow:hidden;white-space:nowrap" title="Làm hàng">${v.ten_salan}</div>`;
    html+=`</div></div>`;
  });

  // Now line
  if(now>=start&&now<=end){
    const nowX=LABEL_W+(now-start)/dur_ms*days.length*COL_W;
    html+=`<div style="position:absolute;top:38px;bottom:0;left:${nowX}px;width:2px;background:var(--red);z-index:3;pointer-events:none">
      <div style="position:absolute;top:-15px;background:var(--red);color:#fff;font-size:9px;padding:1px 5px;border-radius:3px;transform:translateX(-50%)">${now.getHours()}:${String(now.getMinutes()).padStart(2,'0')}</div>
    </div>`;
  }
  html+=`</div>`;
  wrap.innerHTML=html;
}

// ===== SURVEYS =====
function renderSurveys(){
  const q=(document.getElementById('ssrch').value||'').toLowerCase();
  const df=document.getElementById('sfrom').value, dt=document.getElementById('sto').value;
  const bf=document.getElementById('sfbarge').value;
  let rows=S.surveys.filter(s=>{
    if(q&&!s.ten_salan.toLowerCase().includes(q)&&!(s.voyage_no||'').includes(q)) return false;
    if(bf&&s.ma_salan!==bf) return false;
    if(df&&s.ngay_survey){const sd=s.ngay_survey.split('/');if(sd.length===3&&sd[2]+'-'+sd[1]+'-'+sd[0]<df) return false;}
    if(dt&&s.ngay_survey){const sd=s.ngay_survey.split('/');if(sd.length===3&&sd[2]+'-'+sd[1]+'-'+sd[0]>dt) return false;}
    return true;
  });
  const all=S.surveys, adm=all.reduce((s,r)=>s+r.damaged,0), acl=all.reduce((s,r)=>s+r.clean,0),
        arp=all.reduce((s,r)=>s+r.repo,0), atm=all.reduce((s,r)=>s+r.termites,0), atot=all.reduce((s,r)=>s+r.so_luong,0);
  document.getElementById('sstats-top').innerHTML=
    sc('TỔNG CONTAINERS',fmt(atot),'cyan')+sc('DAMAGED',fmt(adm),'red')+
    sc('CLEAN',fmt(acl),'green')+sc('REPO',fmt(arp),'cyan')+sc('TERMITES',fmt(atm),'yellow');
  const fdm=rows.reduce((s,r)=>s+r.damaged,0), fcl=rows.reduce((s,r)=>s+r.clean,0),
        frp=rows.reduce((s,r)=>s+r.repo,0), ftm=rows.reduce((s,r)=>s+r.termites,0), ftot=rows.reduce((s,r)=>s+r.so_luong,0);
  document.getElementById('sstats-f').innerHTML=
    sc2('TỔNG CONTAINERS',fmt(ftot),'cyan','')+
    sc2('DAMAGED',fmt(fdm),'red',ftot?(fdm/ftot*100).toFixed(1)+'%':'')+
    sc2('CLEAN',fmt(fcl),'green',ftot?(fcl/ftot*100).toFixed(1)+'%':'')+
    sc2('REPO',fmt(frp),'cyan',ftot?(frp/ftot*100).toFixed(1)+'%':'')+
    sc2('TERMITES',fmt(ftm),'yellow',ftot?(ftm/ftot*100).toFixed(1)+'%':'');
  const tb=document.getElementById('stbody');
  if(!rows.length){tb.innerHTML=`<tr><td colspan="12" style="text-align:center;padding:32px;color:var(--text3)">Không có dữ liệu</td></tr>`;return;}
  tb.innerHTML=rows.map((s,i)=>`<tr>
    <td style="color:var(--text3)">${i+1}</td>
    <td class="td-n">${s.ten_salan}</td>
    <td style="color:var(--text2)">${s.voyage_no||'—'}</td>
    <td><span class="badge b-sv" style="background:rgba(0,212,255,.1);border-color:rgba(0,212,255,.3);color:var(--cyan)">${s.loai_cont||'—'}</span></td>
    <td style="text-align:right">${fmt(s.so_luong)}</td>
    <td style="text-align:center"><span class="cbdg dm">${s.damaged}</span></td>
    <td style="text-align:center"><span class="cbdg cl">${s.clean}</span></td>
    <td style="text-align:center"><span class="cbdg rp">${s.repo}</span></td>
    <td style="text-align:center"><span class="cbdg tm">${s.termites}</span></td>
    <td style="text-align:right;font-weight:600">${fmt(s.so_luong)}</td>
    <td style="color:var(--text2)">${s.ngay_survey||'—'}</td>
    <td><div class="acts">
      <div class="ibtn e" onclick='openSurveyModal(${jstr(s)})' title="Sửa">✎</div>
      <div class="ibtn d" onclick="confDel('survey',${s.seq},'Xoá survey này?')" title="Xoá">🗑</div>
    </div></td>
  </tr>`).join('');
}
function openSurveyModal(s=null,pv=null){
  document.getElementById('ms-title').textContent=s?'Chỉnh sửa Survey':'Thêm Survey';
  _v('ms-seq',s?s.seq:''); _v('ms-ngay',s?toDateInp(s.ngay_survey):todayStr());
  _v('ms-loai',s?s.loai_cont:'40E'); _v('ms-sl',s?s.so_luong:0);
  _v('ms-dm',s?s.damaged:0); _v('ms-cl',s?s.clean:0); _v('ms-rp',s?s.repo:0); _v('ms-tm',s?s.termites:0);
  const sel=document.getElementById('ms-voy');
  sel.innerHTML='<option value="">-- Chọn voyage --</option>'+
    S.voyages.map(v=>`<option value="${v.seq}" data-ma="${v.ma_salan}" data-ten="${v.ten_salan}" data-vno="${v.voyage_no||''}"
      ${s&&s.voyage_seq==v.seq?'selected':''} ${pv&&pv.seq==v.seq?'selected':''}
    >${v.ten_salan} — VOY ${v.voyage_no||'N/A'}</option>`).join('');
  calcSvTotal(); openOv('ms');
}
function calcSvTotal(){
  const d=+_g('ms-dm')||0, c=+_g('ms-cl')||0, r=+_g('ms-rp')||0, t=+_g('ms-tm')||0;
  document.getElementById('sv-chk').textContent=d+c+r+t;
  document.getElementById('sv-ref').textContent=_g('ms-sl')||0;
}
async function saveSurvey(){
  const seq=_g('ms-seq'), sel=document.getElementById('ms-voy'), vseq=sel.value;
  const opt=sel.options[sel.selectedIndex];
  if(!vseq){toast('Vui lòng chọn voyage','err');return;}
  const res=await post({action:seq?'updateSurvey':'saveSurvey',seq,voyage_seq:vseq,
    ma_salan:opt?opt.dataset.ma:'',ten_salan:opt?opt.dataset.ten:'',voyage_no:opt?opt.dataset.vno:'',
    ngay_survey:_g('ms-ngay'),loai_cont:_g('ms-loai'),so_luong:_g('ms-sl'),
    damaged:_g('ms-dm'),clean:_g('ms-cl'),repo:_g('ms-rp'),termites:_g('ms-tm')});
  if(res.success){toast(seq?'Đã cập nhật':'Đã thêm survey','ok');closeOv('ms');await loadAll();}
  else toast(res.error||'Lỗi','err');
}

// ===== IMPORT =====
function openImportSurvey(){
  S.importRows=[];
  document.getElementById('iprev').style.display='none';
  document.getElementById('ibtn').disabled=true;
  document.getElementById('ifile').value='';
  openOv('mi');
}
function handleImport(e){
  const file=e.target.files[0]; if(!file)return;
  const reader=new FileReader();
  reader.onload=ev=>{
    try{
      const lines=ev.target.result.split('\n').filter(l=>l.trim());
      const rows=lines.slice(1).map(l=>{
        const c=l.split(',').map(x=>x.replace(/"/g,'').trim());
        return{ma_salan:c[0]||'',ten_salan:c[1]||'',voyage_no:c[2]||'',
          ngay_survey:c[3]||'',loai_cont:c[4]||'40E',so_luong:+c[5]||0,
          damaged:+c[6]||0,clean:+c[7]||0,repo:+c[8]||0,termites:+c[9]||0,voyage_seq:''};
      }).filter(r=>r.ma_salan);
      S.importRows=rows;
      const p=document.getElementById('iprev'); p.style.display='block';
      p.textContent=`Đọc được ${rows.length} dòng từ file. Nhấn Import để xác nhận.`;
      document.getElementById('ibtn').disabled=rows.length===0;
    }catch(e){toast('Lỗi đọc file: '+e.message,'err');}
  };
  reader.readAsText(file);
}
async function confirmImport(){
  if(!S.importRows.length)return;
  const res=await post({action:'importSurveys',rows:S.importRows});
  if(res.success){toast(`Import thành công ${res.imported} dòng`,'ok');closeOv('mi');await loadAll();}
  else toast(res.error||'Lỗi','err');
}

// ===== DELETE =====
function confDel(type,seq,msg){
  document.getElementById('conf-msg').textContent=msg;
  document.getElementById('conf-ok').onclick=()=>doDel(type,seq);
  openOv('mconf');
}
async function doDel(type,seq){
  const am={barge:'deleteBarge',voyage:'deleteVoyage',survey:'deleteSurvey'};
  const res=await post({action:am[type],seq});
  if(res.success){toast('Đã xoá','ok');closeOv('mconf');await loadAll();}
  else toast(res.error||'Lỗi','err');
}

// ===== EXPORT =====
function exportBargesExcel(){
  const c=['STT','Mã','Tên sà lan','Số đăng ký','Trọng tải','TEUs','Năm đóng','Tình trạng'];
  const d=S.barges.map((b,i)=>[i+1,b.code,b.ten,b.so_dang_ky,b.trong_tai,b.so_teus,b.nam_dong,b.tinh_trang]);
  dlCsv('Danh_sach_sa_lan.csv',c,d);
}
function exportVoyagesExcel(){
  const c=['STT','Sà lan','Voyage','Loại hàng','Số lượng','POL','POD','ETA','ETD','Bắt đầu','Kết thúc','Survey'];
  const d=S.voyages.map((v,i)=>[i+1,v.ten_salan,v.voyage_no,v.loai_hang,v.so_luong,v.pol,v.pod,v.eta,v.etd,v.bat_dau,v.ket_thuc,v.trang_thai_survey]);
  dlCsv('Ke_hoach_sa_lan.csv',c,d);
}
function exportSurveyExcel(){
  const c=['STT','Sà lan','Voyage','Loại','Số lượng','Damaged','Clean','Repo','Termites','Ngày survey'];
  const d=S.surveys.map((s,i)=>[i+1,s.ten_salan,s.voyage_no,s.loai_cont,s.so_luong,s.damaged,s.clean,s.repo,s.termites,s.ngay_survey]);
  dlCsv('Bao_cao_survey.csv',c,d);
}
function dlCsv(n,c,d){
  const bom='\uFEFF', csv=bom+[c,...d].map(r=>r.map(x=>`"${String(x||'').replace(/"/g,'""')}"`).join(',')).join('\n');
  const a=document.createElement('a'); a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv;charset=utf-8'}));
  a.download=n; a.click();
}

// ===== HELPERS =====
function fillDropdowns(){
  const gf=document.getElementById('gfbarge'), gc=gf.value;
  gf.innerHTML='<option value="">-- Tất cả sà lan --</option>'+S.barges.map(b=>`<option value="${b.code}" ${b.code===gc?'selected':''}>${b.code} — ${b.ten}</option>`).join('');
  const sf=document.getElementById('sfbarge'), sc2=sf.value;
  sf.innerHTML='<option value="">Tất cả sà lan</option>'+S.barges.map(b=>`<option value="${b.code}" ${b.code===sc2?'selected':''}>${b.code} — ${b.ten}</option>`).join('');
}
function sc(l,v,c){return `<div class="stat-card ${c}"><div class="stat-lbl">${l}</div><div class="stat-val ${c}">${v}</div></div>`;}
function sc2(l,v,c,s){return `<div class="stat-card ${c}"><div class="stat-lbl">${l}</div><div class="stat-val ${c}">${v}</div>${s?`<div class="stat-sub2">${s}</div>`:''}</div>`;}
function fmt(n){if(n===undefined||n===null||n==='')return '—';return Number(n).toLocaleString('vi-VN');}
function parseDt(s){
  if(!s)return null;
  if(s.includes('T'))return new Date(s);
  const p=s.split(' '), dp=p[0].split('/');
  if(dp.length===3){const tp=p[1]?p[1].split(':'):['0','0'];return new Date(+dp[2],dp[1]-1,+dp[0],+tp[0]||0,+tp[1]||0);}
  return new Date(s);
}
function toLocal(s){if(!s)return'';const d=parseDt(s);if(!d||isNaN(d))return'';return d.toISOString().slice(0,16);}
function toDateInp(s){if(!s)return'';const dp=s.split('/');if(dp.length===3)return`${dp[2]}-${dp[1].padStart(2,'0')}-${dp[0].padStart(2,'0')}`;return s;}
function todayStr(){const d=new Date();return`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;}
function openOv(id){document.getElementById(id).classList.add('open');}
function closeOv(id){document.getElementById(id).classList.remove('open');}
function _g(id){return document.getElementById(id).value;}
function _v(id,v){const el=document.getElementById(id);if(el)el.value=v;}
function jstr(o){return JSON.stringify(o).replace(/"/g,'&quot;');}
function toast(msg,type='ok'){
  const el=document.getElementById('toast'); el.textContent=msg; el.className='show '+type;
  clearTimeout(el._t); el._t=setTimeout(()=>el.classList.remove('show'),3000);
}
document.querySelectorAll('.ov').forEach(el=>el.addEventListener('click',e=>{if(e.target===el)el.classList.remove('open');}));
</script>
